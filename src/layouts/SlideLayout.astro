---
import type { CollectionEntry } from "astro:content";
import BaseHead from "@/components/BaseHead.astro";
import { siteConfig } from "@/site.config";

interface Props {
  slide: CollectionEntry<"slide">;
}

const { slide } = Astro.props;
const { title, description } = slide.data;
const urlObj = new URL(siteConfig.url);
const basePath = urlObj.pathname && urlObj.pathname !== "/" ? urlObj.pathname.replace(/\/$/, "") : "";
const socialImage = `/og-image/${slide.id}.png`;

const meta = {
  title,
  description,
  ogImage: socialImage,
};
---

<!doctype html>
<html lang={siteConfig.lang}>
  <head>
    <BaseHead {...meta} />
    <style>
      html, body {
        margin: 0;
        padding: 0;
        height: 100%;
        width: 100%;
      }
      /* Make iframe responsive and remove padding margins */
      body { background: #111; }
      .slidev-iframe { background: #111; }
      .slide-controls {
        position: fixed;
        top: 20px;
        right: 20px;
        z-index: 1000;
        display: flex;
        gap: 10px;
      }
      .slide-controls button {
        padding: 8px 12px;
        background: rgba(0, 0, 0, 0.7);
        color: white;
        border: none;
        border-radius: 4px;
        cursor: pointer;
        font-size: 14px;
      }
      .slide-controls button:hover {
        background: rgba(0, 0, 0, 0.9);
      }
      .slidev-iframe {
        position: fixed;
        inset: 0;
        width: 100vw;
        height: 100vh;
        border: none;
      }
    </style>
  </head>
  <body>
    <div class="slide-controls">
      <button onclick="window.location.href='/slides/'">← Back to Slides</button>
    </div>
    <iframe
      class="slidev-iframe"
      title={title}
      src={`${basePath}/slides-embed/${slide.id}/index.html`}
      allow="clipboard-write; clipboard-read;"
    />
  </body>
</html>
